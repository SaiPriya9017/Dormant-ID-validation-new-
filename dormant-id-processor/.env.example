# ============================================================================
# IBM Login API Configuration
# ============================================================================

# IBM Login API Endpoints
TOKEN_URL=https://login.ibm.com/v1.0/endpoint/default/token
USERS_API_URL=https://login.ibm.com/v2.0/Users
BLUEPAGES_API_URL=https://bluepages.ibm.com/BpHttpApisv3/slaphapi

# IBM API Credentials (REQUIRED - Get from IBM Cloud)
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# ============================================================================
# Processing Settings
# ============================================================================

# Batch Processing
BATCH_SIZE=50
CONCURRENCY=5
MAX_RETRIES=3
RETRY_DELAY=2
REQUEST_TIMEOUT=30

# Token Cache Duration (seconds)
TOKEN_CACHE_DURATION=3600

# ============================================================================
# Directories
# ============================================================================

INPUT_DIR=./input
OUTPUT_DIR=./output
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs